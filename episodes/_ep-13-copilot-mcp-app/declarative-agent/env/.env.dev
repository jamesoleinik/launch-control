# Microsoft 365 Agents Toolkit environment file (dev).
# The toolkit fills in most of these during `provision`. The two starred
# fields below MUST be set by you before provisioning.

TEAMSFX_ENV=dev

# ⭐ Your Dataverse environment host, without protocol and without trailing slash.
#   Example: org40ae6a46.crm.dynamics.com
DATAVERSE_HOST=

# Filled in by `aadApp/create`:
AAD_APP_CLIENT_ID=
AAD_APP_OBJECT_ID=
AAD_APP_TENANT_ID=
AAD_APP_OAUTH_AUTHORITY=
AAD_APP_OAUTH_AUTHORITY_HOST=

# Filled in by `oauth/register`:
OAUTH_REGISTRATION_ID=

# Filled in by `teamsApp/create`:
TEAMS_APP_ID=
TEAMS_APP_PUBLISHED_APP_ID=
